<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}nattsu_tt.svg`} type="image/svg+xml" sizes="any" />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}nattsu_1920_1080.webp`} />
    <title>natʇsu</title>
    <meta http-equiv="refresh" content="0; url=opus/" />
    <script>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const mode = params.get('mode');
        if (mode === 'about') {
          window.location.replace('aboutme/' + window.location.hash);
          return;
        }
        window.location.replace('opus/' + window.location.search + window.location.hash);
      })();
    </script>
  </head>
  <body>
    <p><a href="opus/">Go to opus page</a></p>
  </body>
</html>
